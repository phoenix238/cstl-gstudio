# GEMINI_API_KEY: Required for Gemini AI API calls (transcription, summarisation, booking parse).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted (OAuth callbacks, self-referential links).
APP_URL="MY_APP_URL"

# Optional: seed demo clients on first login (development only).
# VITE_SEED_SAMPLE_CLIENTS="true"